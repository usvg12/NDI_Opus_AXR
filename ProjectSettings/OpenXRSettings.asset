%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &1
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 0}
  m_Name: OpenXR Settings
  m_EditorClassIdentifier:
  # OpenXR configuration for AndroidXR / Samsung Galaxy XR
  # Render Mode: Multi-pass stereo (compatibility) or Single Pass Instanced (performance)
  renderMode: 1  # 0=Multi-pass, 1=Single Pass Instanced
  depthSubmissionMode: 1  # Submit depth for reprojection
  features:
    # Core AndroidXR features
    - name: Android XR Session Management
      enabled: true
    - name: Hand Tracking Subsystem
      enabled: true
    - name: Eye Gaze Interaction
      enabled: true
    - name: Passthrough
      enabled: true
    - name: Composition Layers
      enabled: true
    - name: Foveated Rendering
      enabled: true
    - name: Unbounded Reference Space
      enabled: true
  interactionProfiles:
    - name: Hand Interaction Profile
      enabled: true
    - name: Eye Gaze Interaction Profile
      enabled: true
